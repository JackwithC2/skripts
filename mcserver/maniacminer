# Break Block System
on break:
    if {gameon} = 1:
        if player's held item is not a pickaxe:
            cancel event
        if player's held item = iron pickaxe named "&2Pickaximum &3I":
            if event-block is cobblestone:
                clear the drops
                pointsAdd(player, event-block)
                blockRegen(location of event-block)
