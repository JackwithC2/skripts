                blockRegen(location of event-block)
                add 5 to {PersonalCoins::%player's uuid%}
            if event-block is iron ore:
                cancel event
            if event-block is gold ore:
                cancel event
            if event-block is emerald ore:
                cancel event
        if player's held item = iron pickaxe named "&2Pickaximum &3III":
            if event-block is cobblestone:
                clear the drops
                pointsAdd(player, event-block)
                blockRegen(location of event-block)
                add 2 to {PersonalCoins::%player's uuid%}
            if event-block is diamond ore:
                cancel event
            if event-block is coal ore:
                clear the drops
                pointsAdd(player, event-block)
                blockRegen(location of event-block)
                add 5 to {PersonalCoins::%player's uuid%}
            if event-block is iron ore:
                clear the drops
                pointsAdd(player, event-block)
                blockRegen(location of event-block)
                add 7 to {PersonalCoins::%player's uuid%}
            if event-block is gold ore:
                cancel event
            if event-block is emerald ore:
