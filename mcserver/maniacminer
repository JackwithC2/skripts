                    add 35 to {points::red}
                else:
                    add 10 to {points::blue}
                blockRegen(location of event-block)
                add 12 to {PersonalCoins::%player's uuid%}
            if event-block is emerald ore:
                cancel event     
# Functions
function gameEnd():
    if {points::red} >= {points::blue}:
        broadcast "&3[&6Survivor&3]&2: Red has won!"
        RemovePoints()
        set {gameondiskysendmmres} to 1
    if {points::blue} >= {points::red}:
        broadcast "&3[&6Survivor&3]&2: Blue has won!"
        set {gameondiskysendmmres} to 2
        RemovePoints()
function pointsAdd(P: player, I: itemtype):
    if {team::%{_P}'s uuid%} = "red": # Checks for the team
        add {blocks::points::%{_I}%} to {points::red}
    if {team::%{_P}'s uuid%} = "blue":
        add {blocks::points::%{_I}%} to {points::blue}
function RemovePoints():
    set {points::red} to 0
    set {points::blue} to 0
    set {br} to 1

function blockRegen(loc: location):
    wait 1 ticks
    set block at {_loc} to bedrock
    #add location of block at {_loc} to {-locs::*} I might Enable this idk
    wait 1 seconds
    if {br} = 1:
        wait 1 seconds
        chance of 100%:
            set block at {_loc} to cobblestone
    if {br} = 2:
        wait 5.5 seconds
        chance of 100%:
            set block at {_loc} to cobblestone
        chance of 45%:
            set block at {_loc} to coal ore
        chance of 20%:
            set block at {_loc} to iron ore 
    if {br} = 3:
        wait 5 seconds
        chance of 100%:
            set block at {_loc} to cobblestone
        chance of 50%:
            set block at {_loc} to coal ore
        chance of 41%:
            set block at {_loc} to iron ore
        chance of 25%:
            set block at {_loc} to gold ore
    if {br} = 4:
        wait 4.5 seconds
        chance of 100%:
            set block at {_loc} to cobblestone
        chance of 50%:
            set block at {_loc} to coal ore
        chance of 41%:
            set block at {_loc} to iron ore
        chance of 25%:
            set block at {_loc} to gold ore

function blocksDelete():
    delete {blocks::points::*}

function blocksLoad(I: itemtype, points: int):
    set {blocks::points::%{_I}%} to {_points}

function regenores():
    loop {-locs::*}:
        set block at loop-value to cobblestone



every 5 ticks:
    if {points::blue} >= {points::red}:
        set {wtmm} to 1
    if {points::red} >= {points::blue}:
        set {wtmm} to 2
    loop all players:
        if {gameon} is 1:
            if {team::%loop-player's uuid%} = "red":
                if {wtmm} is 2:
                    set action bar of loop-player to "&2Personal Points: %{PersonalCoins::%loop-player's uuid%}%&4 W Team Points %{points::red}%"
                if {wtmm} is 1:
                    set action bar of loop-player to "&2Personal Points: %{PersonalCoins::%loop-player's uuid%}%&4 L Team Points %{points::red}%"
            if {team::%loop-player's uuid%} = "blue":
                if {wtmm} is 1:
                    set action bar of loop-player to "&2Personal Points: %{PersonalCoins::%loop-player's uuid%}%&3 W Team Points %{points::blue}%"
                if {wtmm} is 2:
                    set action bar of loop-player to "&2Personal Points: %{PersonalCoins::%loop-player's uuid%}%&3 L Team Points %{points::blue}%"
